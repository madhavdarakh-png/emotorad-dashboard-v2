# ─────────────────────────────────────────────────────────────────────────────
# Required: Google Service Account credentials (JSON stringified)
# Add the full JSON content of your service account key as a single-line string.
# The service account must have Viewer access to the Google Sheet.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_SA_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─────────────────────────────────────────────────────────────────────────────
# Optional: OMS API credentials (placeholder — connect when OMS is ready)
# ─────────────────────────────────────────────────────────────────────────────
OMS_API_KEY=
OMS_API_URL=
