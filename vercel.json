{
  "version": 2,
  "functions": {
    "api/sheet.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/dealer.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/sheet",  "dest": "/api/sheet.js"  },
    { "src": "/api/dealer", "dest": "/api/dealer.js" },
    { "src": "/(.*)",       "dest": "/index.html"    }
  ]
}
